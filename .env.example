# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# Ping Federate Configuration
# ============================================

# Base URL of Ping Federate server
# Example: https://pf.example.com (note: include port if not standard)
PF_BASE_URL=https://pingfederate.example.com

# OAuth 2.0 Client credentials for TV Streaming App
# OAuth 2.0 > Clients > Create Client
TV_CLIENT_ID=tv-app-client
TV_CLIENT_SECRET=your-client-secret-here

# OAuth 2.0 Client credentials for TV Station App (Authorization Code Grant)
# OAuth 2.0 > Clients > Create Client
STATION_CLIENT_ID=tv-station-client
STATION_CLIENT_SECRET=your-station-client-secret-here

# Admin API Key (for server-to-server communication)
# System > API Keys > Create API Key
PF_ADMIN_API_KEY=your-admin-api-key-here

# ============================================
# Application Configuration
# ============================================

# TV Streaming App port (requests device codes, uses Device Code Grant and CIBA)
TV_APP_PORT=3000

# TV Station App port (authorizes device codes, uses Authorization Code Grant)
TV_STATION_APP_PORT=3001

# ============================================
# Application URLs
# ============================================

# Base URL for TV Station App (used in redirects)
STATION_APP_BASE_URL=http://localhost:3001

# TV Streaming App URL (shown in TV Station app for reference)
TV_STREAMING_APP_URL=http://localhost:3000

# ============================================
# Session Configuration
# ============================================

# Session secret for TV Streaming app (use a random string)
TV_SESSION_SECRET=tv-session-secret-change-me-in-production

# Session secret for TV Station app (use a random string)
STATION_SESSION_SECRET=station-session-secret-change-me-in-production

# ============================================
# Environment
# ============================================

# Set to 'production' for production deployment
NODE_ENV=development

# ============================================
# Logging
# ============================================

# Enable debug logging (comma-separated)
# Example: DEBUG=express:*,pf:*
DEBUG=
# Database (when moving from in-memory)
# ============================================

# MongoDB connection string (future)
# MONGODB_URI=mongodb://localhost:27017/device-auth-demo

# Redis connection string (for session storage)
# REDIS_URL=redis://localhost:6379

# ============================================
# Notification Service (for CIBA push)
# ============================================

# SMS Provider (twilio, sns, etc.)
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# ============================================
# Security (Production Only)
# ============================================

# HTTPS Certificate paths
# CERT_PATH=/path/to/cert.pem
# KEY_PATH=/path/to/key.pem

# Rate limiting configuration
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS Configuration
# ============================================

# Allowed origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://example.com
